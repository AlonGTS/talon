{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "tracker-so: live",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/tracker-so.py",
            "args": ["--mode", "live"],
            "console": "integratedTerminal"
        },
        {
            "name": "tracker-so: playback",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/tracker-so.py",
            "args": ["--mode", "playback", "--loop"],
            "console": "integratedTerminal"
        },
        {
            "name": "GCS: Pi (auto from config.toml)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/gcs.py",
            "args": [],
            "console": "integratedTerminal"
        },
        {
            "name": "GCS: connect to Pi (manual IP)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/gcs.py",
            "args": ["--pi", "${input:piIp}"],
            "console": "integratedTerminal"
        }
    ],
    "inputs": [
        {
            "id": "piIp",
            "type": "promptString",
            "description": "Pi IP address",
            "default": "192.168.1.34"
        }
    ]
}
